PORT=5050
NODE_ENV=development

# Same Postgres as backend to share whatsapp_sessions
POSTGRES_URL=postgres://username:password@localhost:5432/clinicdb

# Security / crypto
WA_WEB_AUTH_SECRET=replace-with-32+char-secret
WA_WEB_BRIDGE_API_KEY=replace-bridge-api-key
WA_WEB_BACKEND_SHARED_SECRET=replace-shared-secret

# Backend callback target
WA_BACKEND_URL=http://localhost:4000

# Misc
LOG_LEVEL=info
WA_WEB_BRIDGE_TIMEOUT_MS=15000