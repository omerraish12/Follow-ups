####################################
# Server
####################################
PORT=5000
NODE_ENV=development

####################################
# Database
####################################
# Preferred: pooled URL (Supabase pooler / Neon pooled, etc.)
POSTGRES_URL=postgresql://<user>:<password-url-encoded>@<pooler-host>:5432/postgres
DATABASE_URL=postgresql://<user>:<password-url-encoded>@<pooler-host>:5432/postgres
SUPABASE_DB_URL=postgresql://<user>:<password-url-encoded>@<pooler-host>:5432/postgres
POSTGRES_PRISMA_URL=postgresql://<user>:<password-url-encoded>@<pooler-host>:5432/postgres
POSTGRES_URL_NON_POOL=postgresql://<user>:<password-url-encoded>@<direct-host>:5432/postgres

# Fallback parts (used only if URL vars above are missing)
POSTGRES_HOST=<db-host>
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<raw-password>
POSTGRES_PORT=5432

# Pool / retry tuning
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=20000
DB_QUERY_RETRIES=3
=

####################################
# Frontend (CORS + links)
####################################
FRONTEND_URL=http://localhost:8080

####################################
# Twilio
####################################
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=          # or just use the Messaging Service SID below for better practice
TWILIO_MESSAGING_SERVICE_SID= 
TWILIO_SANDBOX_URL=https://www.twilio.com/console/sms/whatsapp/sandbox
TWILIO_SANDBOX_JOIN_CODE=join wood-silent
TWILIO_SANDBOX_NUMBER=whatsapp:+14155238886

####################################
# Email / Notifications
####################################
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
CONTACT_NOTIFICATION_EMAIL=

####################################
# Deployment hints
####################################
# Set VERCEL or AWS_LAMBDA_FUNCTION_NAME automatically when running serverless
# Leave blank otherwise
VERCEL=
AWS_LAMBDA_FUNCTION_NAME=
