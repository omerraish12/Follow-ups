# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (prefer URL; per-service poolers are fine)
DATABASE_URL=postgres://username:password@localhost:5432/clinicdb
POSTGRES_URL=postgres://username:password@localhost:5432/clinicdb
POSTGRES_HOST=localhost
POSTGRES_DATABASE=clinicdb
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
DB_CONNECTION_TIMEOUT=20000
DB_QUERY_RETRIES=3

# Supabase (keep secrets out of git in real envs)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRE=7d
PASSWORD_SALT_ROUNDS=10

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="CRM System <noreply@crm.com>"

# CORS
CORS_ORIGIN=http://localhost:5173

# WhatsApp provider switching (Web bridge + optional Meta Cloud)
WA_WEB_BRIDGE_URL=http://localhost:5050
WA_WEB_BRIDGE_API_KEY=replace-bridge-api-key
WA_WEB_BACKEND_SHARED_SECRET=replace-shared-secret
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ACCOUNT_ID=
CLOUD_API_ACCESS_TOKEN=
WHATSAPP_GRAPH_BASE=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0

# Legacy Cellact (leave blank if unused)
CELLACT_API_USER=
CELLACT_API_PASSWORD=
CELLACT_APP_ID=

# Logging
LOG_LEVEL=info
