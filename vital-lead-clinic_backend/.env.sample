# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database (Supabase-only; backend uses Supabase RPC, not pg)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.tsbxrlxggvgrwdpdwfza.supabase.co:5432/postgres?sslmode=require
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.tsbxrlxggvgrwdpdwfza.supabase.co:5432/postgres?sslmode=require

# Auth
JWT_SECRET=replace-with-long-random-string
